server {
    listen 80;
    listen [::]:80;
    server_name vsharev.com www.vsharev.com;
    location /img/ {
        alias /opt/server/img/;
        autoindex on;
    }
    
    # 重定向HTTP到HTTPS
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name vsharev.com www.vsharev.com;
    location /img/ {
        alias /opt/server/img/;
        autoindex on;
    }

    # SSL证书配置
    ssl_certificate /etc/letsencrypt/live/vsharev.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/vsharev.com/privkey.pem;
    
    # 代理到Node.js
    location /api/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
    
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
    }
}

# ===== CHEERFUL 网站（子域名方式）=====
server {
    listen 80;
    listen [::]:80;
    server_name cheerful.vsharev.com;
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name cheerful.vsharev.com;

    # 复用主域名证书（需证书支持泛域名），或单独申请：
    # certbot --nginx -d cheerful.vsharev.com
    ssl_certificate /etc/letsencrypt/live/vsharev.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/vsharev.com/privkey.pem;

    client_max_body_size 50M;

    # 上传文件
    location /uploads/ {
        proxy_pass http://127.0.0.1:4000/uploads/;
    }

    # 所有请求转发到 CHEERFUL Node.js（端口4000）
    location / {
        proxy_pass http://127.0.0.1:4000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
